# =============================================================================
# SATIS Aero – Environment Variables
# =============================================================================
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# Production / Preview / Development values are managed in the Vercel
# dashboard under Project Settings → Environment Variables.
# Never commit `.env.local` or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (Spam protection on /kontakt and /en/contact)
# -----------------------------------------------------------------------------
# Public site key – embedded in the client bundle, safe to expose.
# Cloudflare Dashboard → Turnstile → Your Site → Site Key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only secret – used by the Server Action to call the siteverify
# endpoint. NEVER expose this to the client.
# Cloudflare Dashboard → Turnstile → Your Site → Secret Key
TURNSTILE_SECRET_KEY=

# -----------------------------------------------------------------------------
# Resend (transactional mail dispatch from the contact form)
# -----------------------------------------------------------------------------
# API key from https://resend.com/api-keys – server-only.
# Without this key the contact form falls back to logging the submission
# on the server (for local development); production MUST set this.
RESEND_API_KEY=

# Optional overrides – defaults are used when these are not set.
# CONTACT_TO_EMAIL is the inbox that receives every contact submission.
CONTACT_TO_EMAIL=info@satis.aero
# CONTACT_FROM_EMAIL must be a domain you have verified in the Resend
# dashboard (e.g. noreply@satis.aero once the SPF/DKIM records are in
# place for satis.aero).
CONTACT_FROM_EMAIL=noreply@satis.aero
