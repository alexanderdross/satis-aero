# =============================================================================
# SATIS Aero – Environment Variables
# =============================================================================
# Copy this file to `.env.local` for local development:
#   cp .env.example .env.local
#
# Production / Preview / Development values are managed in the Vercel
# dashboard under Project Settings → Environment Variables.
# Never commit `.env.local` or any file containing real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (Spam protection on /contact – see konzept.md §9.1)
# -----------------------------------------------------------------------------
# Public site key – embedded in the client bundle, safe to expose.
# Cloudflare Dashboard → Turnstile → Your Site → Site Key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Server-only secret – used by the Server Action to call the siteverify
# endpoint. NEVER expose this to the client.
# Cloudflare Dashboard → Turnstile → Your Site → Secret Key
TURNSTILE_SECRET_KEY=
